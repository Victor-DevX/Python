def salvation(d1:float, d2:float, h:float, vsand:float, n:float, theta1:float):    #сделаем переменные локальными
 
    #    оставим расчёты
    #Организация перевода единиц измерения
    D1 = d1 * 3                                                   # соотношение ярда к футу = 3
    H = h * 3                                                     # соотношение мили к футам = 5280
    Vsand = vsand * 1.4667                                        # конвертация скорости по формуле


    x = D1 * math.tan(math.radians(theta1))
    L1 = float(math.sqrt((x ** 2) + (D1 ** 2)))
    L2 = float(math.sqrt(((H - x) ** 2) + (d2 ** 2)))


    t = 1/Vsand * (L1 + n * L2)
    return theta1, t


