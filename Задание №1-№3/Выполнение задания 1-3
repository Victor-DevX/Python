def test_speed_scaling():
    
    _, t1 = salvation(8, 10, 50, 5, 2, 39.413)
    _, t2 = salvation(8, 10, 50, 15, 2, 39.413)

    speed_caling = t1 / t2                              # проверка на изменение параметра скорости
    if (speed_caling - 2) > 0:
